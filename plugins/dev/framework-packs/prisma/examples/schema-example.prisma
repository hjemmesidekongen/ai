/**
 * Example: Well-structured Prisma schema
 * Pack: prisma
 * Tags: prisma, schema, database
 *
 * Demonstrates relations, enums, indexes, and schema conventions.
 * Uses Prisma v7 with prisma.config.ts (adapter-based setup).
 */

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums --------------------------------------------------------------------

enum ProjectStatus {
  active
  completed
  archived
}

enum MemberRole {
  owner
  editor
  viewer
}

// --- Models -------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  ownedProjects  Project[]       @relation("ProjectOwner")
  memberships    ProjectMember[]
  activityLogs   ActivityLog[]

  @@map("users")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(active)
  ownerId     String        @map("owner_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  owner    User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  members  ProjectMember[]
  tasks    Task[]

  // Indexes — owner lookup is the most common query pattern
  @@index([ownerId])
  @@index([status])
  @@map("projects")
}

// Junction table with extra fields — use explicit model, not implicit @relation
model ProjectMember {
  projectId String     @map("project_id")
  userId    String     @map("user_id")
  role      MemberRole @default(viewer)
  joinedAt  DateTime   @default(now()) @map("joined_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_members")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  completed   Boolean   @default(false)
  projectId   String    @map("project_id")
  assigneeId  String?   @map("assignee_id")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([assigneeId])
  @@map("tasks")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String   // e.g. "created_project", "completed_task"
  entityId  String   @map("entity_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  // Partial index: recent activity lookups per user
  @@index([userId, createdAt(sort: Desc)])
  @@map("activity_logs")
}
