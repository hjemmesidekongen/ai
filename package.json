{
  "name": "hjemmesidekongen-ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "preflight": "pnpm run lint && pnpm run type:check && pnpm run test && pnpm run build",
    "build": "pnpm --filter @kronen/hooks run build",
    "test": "pnpm --filter @kronen/hook-utils --filter @kronen/hooks run test",
    "lint": "pnpm --filter @kronen/hook-utils --filter @kronen/hooks run lint",
    "type:check": "pnpm --filter @kronen/hook-utils --filter @kronen/hooks run type:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.35.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
